<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="538.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.cust.UIControllers.DebtController">
    <children>
        <Pane prefHeight="71.0" prefWidth="750.0" style="-fx-background-color: eca7ec;">
            <children>
                <Label alignment="CENTER" prefHeight="71.0" prefWidth="750.0" style="-fx-background-color: eca7ec;" text="Stock Management">
                    <font>
                        <Font size="45.0" />
                    </font>
                </Label>
                <Button fx:id="backButton" layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onMouseClicked="#returnToParent" prefHeight="43.0" prefWidth="90.0" style="-fx-background-color: #bc4abc;" text="Back">
                    <font>
                        <Font size="17.0" />
                    </font></Button>
            </children>
        </Pane>
        <TableView fx:id="customerTable" layoutX="14.0" layoutY="120.0" prefHeight="266.0" prefWidth="720.0">
            <columns>
                <TableColumn fx:id="customerID" prefWidth="42.39999485015869" text="ID" visible="false" />
                <TableColumn fx:id="name" editable="false" prefWidth="120.0" text="Name" />
            <TableColumn prefWidth="90.0" text="Product Type" />
            <TableColumn prefWidth="90.0" text="Package Type" />
            <TableColumn prefWidth="60.0" text="Units" />
            <TableColumn prefWidth="90.0" text="Units in a pack" />
                <TableColumn fx:id="balance" prefWidth="90.0" text="Bulk Cost" />
                <TableColumn fx:id="status" prefWidth="90.0" text="Quantity" />
            <TableColumn prefWidth="90.0" text="Stock Limit" />
            </columns>
        </TableView>
        <GridPane layoutX="14.0" layoutY="394.0" prefHeight="130.0" prefWidth="722.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Button mnemonicParsing="false" onMouseClicked="#processRepayment" prefHeight="78.0" prefWidth="362.0" style="-fx-background-color: Purple;" text="Add Non-IPOS Stock" textFill="WHITE">
                    <font>
                        <Font size="29.0" />
                    </font>
                </Button>
                <Button mnemonicParsing="false" onMouseClicked="#manualAccountRestore" prefHeight="78.0" prefWidth="362.0" style="-fx-background-color: Purple; -fx-border-radius: 25;" text="Delete Stock" textFill="WHITE" GridPane.rowIndex="1">
                    <font>
                        <Font size="29.0" />
                    </font>
                </Button>
                <Button mnemonicParsing="false" onMouseClicked="#generateReminders" prefHeight="78.0" prefWidth="362.0" style="-fx-background-color: Purple;" text="Edit Non-IPOS Stock" textFill="WHITE" GridPane.columnIndex="1">
                    <font>
                        <Font size="29.0" />
                    </font>
                </Button>
                <Button mnemonicParsing="false" onMouseClicked="#viewReminders" prefHeight="78.0" prefWidth="362.0" style="-fx-background-color: Purple;" text="Rate Customisation" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <font>
                        <Font size="29.0" />
                    </font>
                </Button>
            </children>
        </GridPane>
        <TextField fx:id="searchField" layoutX="238.0" layoutY="82.0" prefHeight="26.0" prefWidth="275.0" promptText="Search By Name..." />
