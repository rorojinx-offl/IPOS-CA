<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #FFF7B2;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.templates.controller.ReceiptTemplateController">
    <children>
        <Pane prefHeight="71.0" prefWidth="750.0" style="-fx-background-color: yellow;">
            <children>
                <Label layoutX="240.0" layoutY="20.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Receipt Template Editor" />
            </children>
        </Pane>
        <TextField fx:id="headerField" promptText="Header Text" />
        <TextArea fx:id="bodyArea" prefHeight="200.0" promptText="Receipt Body" />
        <TextField fx:id="footerField" promptText="Footer Text" />
        <CheckBox fx:id="logoCheck" text="Show Logo" />
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button onAction="#previewTemplate" style="-fx-background-color: gold;" text="Preview" />
                <Button onAction="#saveTemplate" style="-fx-background-color: gold;" text="Save" />
                <Button onAction="#resetToDefault" style="-fx-background-color: orange;" text="Reset to Default" />
                <Button onAction="#goBack" style="-fx-background-color: red; -fx-text-fill: white;" text="Back" />
            </children>
        </HBox>
    </children>
</VBox>