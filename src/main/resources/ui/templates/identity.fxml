<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #FFF7B2;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.templates.controller.ShopIdentityController">
    <children>
        <Pane prefHeight="71.0" prefWidth="750.0" style="-fx-background-color: yellow;">
            <children>
                <Label layoutX="230.0" layoutY="20.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Shop Identity Configuration" />
            </children>
        </Pane>
        <GridPane alignment="CENTER" hgap="10.0" vgap="10.0">
            <children>
                <Label text="Pharmacy Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="pharmacyNameField" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextArea fx:id="addressArea" prefHeight="80.0" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Logo:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <children>
                        <TextField fx:id="logoPathField" editable="false" prefWidth="200.0" />
                        <Button onAction="#browseLogo" text="Browse..." />
                    </children>
                </HBox>
            </children>
        </GridPane>
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button onAction="#saveIdentity" style="-fx-background-color: gold;" text="Save" />
                <Button onAction="#goBack" style="-fx-background-color: red; -fx-text-fill: white;" text="Back" />
            </children>
        </HBox>
    </children>
</VBox>