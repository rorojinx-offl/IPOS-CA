<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.order.LoggedInController">

    <children>
        <Pane layoutX="-1.0" prefHeight="99.0" prefWidth="600.0" style="-fx-background-color: #ff22ff;">
         <children>
            <Text layoutX="22.0" layoutY="63.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Welcome, ">
               <font>
                  <Font name="System Bold" size="34.0" />
               </font>
            </Text>
            <Text fx:id="loggedInUsername" layoutX="189.0" layoutY="63.0" strokeType="OUTSIDE" strokeWidth="0.0">
               <font>
                  <Font name="System Bold" size="34.0" />
               </font>
            </Text>
         </children></Pane>
        <Button fx:id="logoutButton" layoutX="508.0" layoutY="341.0" mnemonicParsing="false" onAction="#handleLogout" text="Logout" />
    </children>

</AnchorPane>
