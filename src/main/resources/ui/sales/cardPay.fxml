<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="313.0" prefWidth="678.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.sales.UIControllers.CardController">
   <children>
      <Pane prefHeight="71.0" prefWidth="678.0" style="-fx-background-color: Red;">
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="71.0" prefWidth="678.0" text="Enter Card Details">
               <font>
                  <Font name="Agency FB" size="45.0" />
               </font>
            </Label>
            <Button fx:id="backButton" layoutX="20.0" layoutY="14.0" mnemonicParsing="false" onMouseClicked="#returnToParent" prefHeight="43.0" prefWidth="90.0" style="-fx-background-color: DeepSkyBlue;" text="Back" />
         </children>
      </Pane>
      <HBox layoutX="14.0" layoutY="147.0">
         <children>
            <Label text="Card Number ">
               <font>
                  <Font size="19.0" />
               </font>
            </Label>
            <TextField fx:id="cardNo" />
            <Label fx:id="cardNoWarning" textFill="RED">
               <font>
                  <Font size="17.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <HBox layoutX="14.0" layoutY="94.0">
         <children>
            <Label text="Card Vendor ">
               <font>
                  <Font size="19.0" />
               </font>
            </Label>
            <ChoiceBox fx:id="vendor" prefWidth="150.0" />
            <Label fx:id="vendorWarning" textFill="RED">
               <font>
                  <Font size="17.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <HBox layoutX="14.0" layoutY="198.0">
         <children>
            <Label text="Card Expiry ">
               <font>
                  <Font size="19.0" />
               </font>
            </Label>
            <DatePicker fx:id="cardExp" />
            <Label fx:id="cardExpWarning" textFill="RED">
               <font>
                  <Font size="17.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <Button layoutX="34.0" layoutY="243.0" mnemonicParsing="false" onMouseClicked="#pay" prefHeight="56.0" prefWidth="623.0" style="-fx-background-color: LawnGreen;" text="Pay">
         <font>
            <Font size="28.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
