<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="12.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.user.controllers.CreateUserPageController">

<padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
</padding>

<Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Create User Account" />

<TextField fx:id="usernameField" prefWidth="250.0" promptText="Enter username" />

<PasswordField fx:id="passwordField" prefWidth="250.0" promptText="Enter password" />

<TextField fx:id="fullNameField" prefWidth="250.0" promptText="Enter full name" />

<ComboBox fx:id="roleComboBox" prefWidth="250.0" promptText="Select role" />

<Button onMouseClicked="#handleCreateUser" prefWidth="250.0" style="-fx-background-color: E660B3; -fx-text-fill: white;" text="Create User" />
   <Button fx:id="viewAllUsersButton" onMouseClicked="#handleViewAllUsers" prefWidth="250.0" style="-fx-background-color: E660B3; -fx-text-fill: white;" text="View All Users" />
   <Button fx:id="backButton" onMouseClicked="#returnToParent" prefWidth="250.0" style="-fx-background-color: E660B3;" text="Back" textFill="WHITE" />

<Label fx:id="messageLabel" style="-fx-text-fill: red;" text="" />

</VBox>
