<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.order.controllers.TemporaryMenuDashboard">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Button mnemonicParsing="false" onAction="#handleMerchantLogin" prefWidth="200.0" text="Merchant login" />
    <Button mnemonicParsing="false" onAction="#handleCreateUser" prefWidth="200.0" text="Create user/view all users" />
</VBox>
