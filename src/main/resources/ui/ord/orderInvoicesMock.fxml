<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<!-- Mock invoices page: list, inspect, and export selected invoice. -->
<AnchorPane prefHeight="680.0" prefWidth="980.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.ord.UIControllers.orderInvoicesMockController">
   <children>
      <HBox prefHeight="680.0" prefWidth="980.0">
         <children>
            <AnchorPane prefHeight="680.0" prefWidth="260.0" style="-fx-background-color: #181b37;">
               <children>
                  <Label layoutX="24.0" layoutY="280.0" text="INVOICES" textFill="WHITE">
                     <font>
                        <Font size="34.0" />
                     </font>
                  </Label>
                  <Label layoutX="24.0" layoutY="320.0" text="MOCK VIEW" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
            <AnchorPane prefHeight="680.0" prefWidth="720.0">
               <children>
                  <!-- Actions apply to whichever invoice row is currently selected. -->
                  <Label layoutX="24.0" layoutY="20.0" text="Invoices (Mock)">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Button fx:id="loadInvoicesButton" layoutX="24.0" layoutY="60.0" mnemonicParsing="false" onAction="#loadInvoices" prefHeight="34.0" prefWidth="120.0" style="-fx-background-color: #181b37; -fx-text-fill: white;" text="Load Invoices" />
                  <Button fx:id="exportPdfButton" layoutX="154.0" layoutY="60.0" mnemonicParsing="false" onAction="#exportPdf" prefHeight="34.0" prefWidth="120.0" style="-fx-background-color: #f29f3d;" text="Export as PDF" />
                  <Button fx:id="viewDetailsButton" layoutX="284.0" layoutY="60.0" mnemonicParsing="false" onAction="#viewInvoiceDetails" prefHeight="34.0" prefWidth="140.0" style="-fx-background-color: #3f7ab8; -fx-text-fill: white;" text="View Details" />
                  <Button fx:id="backButton" layoutX="632.0" layoutY="636.0" mnemonicParsing="false" onAction="#back" prefHeight="30.0" prefWidth="72.0" text="Back" />
                  <TableView fx:id="invoicesTable" layoutX="24.0" layoutY="108.0" prefHeight="510.0" prefWidth="680.0">
                     <columns>
                        <TableColumn fx:id="invoiceNoColumn" prefWidth="130.0" text="Invoice No" />
                        <TableColumn fx:id="orderNoColumn" prefWidth="130.0" text="Order No" />
                        <TableColumn fx:id="merchantIdColumn" prefWidth="95.0" text="Merchant ID" />
                        <TableColumn fx:id="issuedAtColumn" prefWidth="150.0" text="Issued At" />
                        <TableColumn fx:id="subtotalColumn" prefWidth="85.0" text="Subtotal" />
                        <TableColumn fx:id="vatColumn" prefWidth="85.0" text="VAT" />
                        <TableColumn fx:id="grandTotalColumn" prefWidth="105.0" text="Grand Total" />
                     </columns>
                  </TableView>
                  <Label fx:id="warning" layoutX="24.0" layoutY="634.0" textFill="RED" />
               </children>
            </AnchorPane>
         </children>
      </HBox>
   </children>
</AnchorPane>
