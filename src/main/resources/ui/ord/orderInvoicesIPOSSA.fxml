<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<!-- Real invoices page that reads invoice list/details from IPOS-SA. -->
<AnchorPane prefHeight="680.0" prefWidth="980.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.ord.UIControllers.orderInvoicesIPOSSAController">
   <children>
      <HBox prefHeight="680.0" prefWidth="980.0">
         <children>
            <AnchorPane prefHeight="680.0" prefWidth="260.0" style="-fx-background-color: #181b37;">
               <children>
                  <Label layoutX="24.0" layoutY="280.0" text="INVOICES" textFill="WHITE">
                     <font>
                        <Font size="34.0" />
                     </font>
                  </Label>
                  <Label layoutX="24.0" layoutY="320.0" text="IPOS-SA VIEW" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
            <AnchorPane prefHeight="680.0" prefWidth="720.0">
               <children>
                  <!-- Load fetches all invoices; View Details opens selected invoice text. -->
                  <Label layoutX="24.0" layoutY="20.0" text="Invoices (IPOS-SA)">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Button fx:id="loadInvoicesButton" layoutX="24.0" layoutY="60.0" mnemonicParsing="false" onAction="#loadInvoices" prefHeight="34.0" prefWidth="120.0" style="-fx-background-color: #181b37; -fx-text-fill: white;" text="Load Invoices" />
                  <Button fx:id="viewDetailsButton" layoutX="154.0" layoutY="60.0" mnemonicParsing="false" onAction="#viewInvoiceDetails" prefHeight="34.0" prefWidth="120.0" style="-fx-background-color: #3f7ab8; -fx-text-fill: white;" text="View Details" />
                  <Button fx:id="backButton" layoutX="632.0" layoutY="636.0" mnemonicParsing="false" onAction="#back" prefHeight="30.0" prefWidth="72.0" text="Back" />
                  <TableView fx:id="invoicesTable" layoutX="24.0" layoutY="108.0" prefHeight="510.0" prefWidth="680.0">
                     <columns>
                        <TableColumn fx:id="invoiceIdColumn" prefWidth="120.0" text="Invoice ID" />
                        <TableColumn fx:id="orderIdColumn" prefWidth="120.0" text="Order ID" />
                        <TableColumn fx:id="merchantIdColumn" prefWidth="120.0" text="Merchant ID" />
                        <TableColumn fx:id="invoiceDateColumn" prefWidth="170.0" text="Invoice Date" />
                        <TableColumn fx:id="amountDueColumn" prefWidth="150.0" text="Amount Due" />
                     </columns>
                  </TableView>
                  <Label fx:id="warning" layoutX="24.0" layoutY="634.0" textFill="RED" />
               </children>
            </AnchorPane>
         </children>
      </HBox>
   </children>
</AnchorPane>
