<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<!-- Real order status page for the logged-in merchant via IPOS-SA API. -->
<AnchorPane prefHeight="680.0" prefWidth="980.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.ord.UIControllers.checkOrderStatusIPOSSAController">
   <children>
      <HBox prefHeight="680.0" prefWidth="980.0">
         <children>
            <AnchorPane prefHeight="680.0" prefWidth="260.0" style="-fx-background-color: #181b37;">
               <children>
                  <Label layoutX="24.0" layoutY="280.0" text="ORDER" textFill="WHITE">
                     <font>
                        <Font size="34.0" />
                     </font>
                  </Label>
                  <Label layoutX="24.0" layoutY="320.0" text="STATUS (IPOS-SA)" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
            <AnchorPane prefHeight="680.0" prefWidth="720.0">
               <children>
                  <!-- Shows order ID/date/status/total for easier progress tracking. -->
                  <Label layoutX="24.0" layoutY="20.0" text="Check Order Status (IPOS-SA)">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Button fx:id="refreshButton" layoutX="24.0" layoutY="60.0" mnemonicParsing="false" onAction="#refreshOrders" prefHeight="34.0" prefWidth="120.0" style="-fx-background-color: #181b37; -fx-text-fill: white;" text="Refresh" />
                  <Button fx:id="backButton" layoutX="632.0" layoutY="636.0" mnemonicParsing="false" onAction="#back" prefHeight="30.0" prefWidth="72.0" text="Back" />
                  <TableView fx:id="ordersTable" layoutX="24.0" layoutY="108.0" prefHeight="510.0" prefWidth="680.0">
                     <columns>
                        <TableColumn fx:id="orderIdColumn" prefWidth="170.0" text="Order ID" />
                        <TableColumn fx:id="orderDateColumn" prefWidth="210.0" text="Order Date" />
                        <TableColumn fx:id="statusColumn" prefWidth="140.0" text="Status" />
                        <TableColumn fx:id="totalColumn" prefWidth="150.0" text="Total" />
                     </columns>
                  </TableView>
                  <Label fx:id="warning" layoutX="24.0" layoutY="633.0" textFill="RED" />
               </children>
            </AnchorPane>
         </children>
      </HBox>
   </children>
</AnchorPane>
