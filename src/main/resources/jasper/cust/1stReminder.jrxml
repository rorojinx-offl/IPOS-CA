		<element kind="textField" uuid="5aaec570-d1f0-41db-bb14-4b025dc91752" x="10" y="1" width="140" height="98">
			<expression><![CDATA[$P{C_NAME} + "\n" +
$P{C_ADDRESS} + "\n" + 
"Phone: " + $P{PHONE}]]></expression>
		</element>
		<element kind="textField" uuid="4d97a084-c2e4-4f50-b123-64a4ca521c47" x="10" y="111" width="560" height="100">
			<expression><![CDATA["Dear " + $P{C_NAME} + ",\n\n"
+ "Our records indicate that an outstanding balance of £"
+ new java.text.DecimalFormat("0.00").format($P{DEBT})
+ " remains unpaid from " + $P{PREV_MONTH}.toString() + ".\n\n"
+ "We kindly request that this amount be settled by "
+ $P{NEW_DUE_DATE} + ".\n\n"
+ "If payment has already been made, please disregard this notice.\n\n"
+ "If you have any questions or require assistance, please do not hesitate to contact us.\n\n"]]></expression>
		</element>
	</pageHeader>
