        </element>
        <element kind="textField" uuid="87192a79-8279-45c0-88bc-ad84f6d21b80" x="360" y="30" width="195" height="18" hTextAlign="Right">
            <expression><![CDATA["VAT: " + String.format("£%.2f", $P{VAT})]]></expression>
        </element>
        <element kind="textField" uuid="ed722117-bc4e-4ba2-aa56-af03be267f1f" x="360" y="50" width="195" height="20" bold="true" hTextAlign="Right">
            <expression><![CDATA["Grand Total: " + String.format("£%.2f", $P{GRAND_TOTAL})]]></expression>
        </element>
    </summary>
</jasperReport>
