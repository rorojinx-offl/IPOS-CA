        <element kind="staticText" uuid="fd7193c5-08e4-4271-9502-9e1f82f1b5b9" x="470" y="0" width="85" height="22" mode="Opaque" backcolor="#D6E5F7" hTextAlign="Center" bold="true">
            <text><![CDATA[Total]]></text>
        </element>
    </columnHeader>

    <!-- Detail band repeats once per invoice line item (item, qty, price, total). -->
    <detail>
        <band height="20">
            <element kind="textField" uuid="17b5c321-a0ed-4754-b7b4-9a0c6019a5ff" x="0" y="0" width="85" height="20">
                <expression><![CDATA[$F{itemId}]]></expression>
            </element>
            <element kind="textField" uuid="48f7f8f8-a34f-4f97-af84-f2ef0f8040da" x="85" y="0" width="225" height="20">
                <expression><![CDATA[$F{description}]]></expression>
            </element>
            <element kind="textField" uuid="09593c3d-178f-4f75-9956-a8372f32768d" x="310" y="0" width="75" height="20" hTextAlign="Right">
                <expression><![CDATA[$F{quantity}]]></expression>
            </element>
            <element kind="textField" uuid="f33e98e9-8f97-43eb-805a-ba95dd53b4bc" x="385" y="0" width="85" height="20" hTextAlign="Right">
                <expression><![CDATA[String.format("£%.2f", $F{unitCost})]]></expression>
            </element>
            <element kind="textField" uuid="d9966ca4-c9b9-4729-bfdd-2327c8f9af3a" x="470" y="0" width="85" height="20" hTextAlign="Right">
                <expression><![CDATA[String.format("£%.2f", $F{total})]]></expression>
            </element>
        </band>
    </detail>

    <summary height="74">
        <element kind="textField" uuid="0c36fcb7-8de4-4ac4-b874-19eff8af4d12" x="360" y="10" width="195" height="18" hTextAlign="Right">
