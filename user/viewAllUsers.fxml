<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novastack.iposca.user.controllers.ViewAllUsersController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="All Created Users" />

    <TableView fx:id="usersTable" prefHeight="320.0" prefWidth="700.0">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
            <TableColumn fx:id="usernameColumn" prefWidth="160.0" text="Username" />
            <TableColumn fx:id="roleColumn" prefWidth="140.0" text="Role" />
            <TableColumn fx:id="fullNameColumn" prefWidth="200.0" text="Full Name" />
            <TableColumn fx:id="createdAtColumn" prefWidth="120.0" text="Created At" />
        </columns>
    </TableView>

    <Label fx:id="messageLabel" style="-fx-text-fill: red;" text="" />

    <HBox alignment="CENTER" spacing="12.0">
        <children>
            <ComboBox fx:id="roleComboBox" prefWidth="200.0" promptText="Select new role" />
            <Button mnemonicParsing="false" onMouseClicked="#handleUpdateRole" prefWidth="180.0" text="Update Role" />
            <Button mnemonicParsing="false" onMouseClicked="#handleDeleteUser" prefWidth="180.0" style="-fx-background-color: maroon; -fx-text-fill: white;" text="Delete User" />
        </children>
    </HBox>

    <Button mnemonicParsing="false" onMouseClicked="#returnToParent" prefWidth="200.0" text="Back" />
</VBox>
